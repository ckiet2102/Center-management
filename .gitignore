# Dependency directories (Không đẩy các thư viện cài đặt lên)
node_modules/
client/node_modules/
server/node_modules/

# Environment variables (CỰC KỲ QUAN TRỌNG: Chặn các file chứa mật khẩu)
.env
server/.env
client/.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs (Chặn các file tạm sau khi biên dịch)
dist/
build/
client/dist/

# Logs (Chặn các file ghi nhật ký lỗi hệ thống)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
server/logs/

# AI & Tooling (Chặn các thư mục rác từ công cụ hỗ trợ)
.agent/
openspec/
.DS_Store

# Database (Chặn các bản sao lưu database cục bộ)
*.sql
*.sqlite